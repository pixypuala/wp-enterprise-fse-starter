{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": { "contentSize": "42rem", "wideSize": "76rem" },
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "base", "color": "#ffffff", "name": "Base" },
				{ "slug": "contrast", "color": "#15181d", "name": "Contrast" },
				{ "slug": "muted", "color": "#5a6472", "name": "Muted" },
				{ "slug": "accent", "color": "#0b5d4e", "name": "Accent" },
				{ "slug": "line", "color": "#e2e4e9", "name": "Line" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Display",
					"fontFamily": "\"Fraunces\", \"Iowan Old Style\", Palatino, Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/fraunces-variable.woff2" ]
						}
					]
				},
				{ "slug": "body", "name": "Body", "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif" }
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem" },
				{ "slug": "medium", "name": "Medium", "size": "1.05rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "slug": "large", "name": "Large", "size": "1.5rem", "fluid": { "min": "1.35rem", "max": "1.75rem" } },
				{ "slug": "x-large", "name": "Extra large", "size": "2.25rem", "fluid": { "min": "1.9rem", "max": "2.75rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "slug": "30", "name": "2", "size": "1rem" },
				{ "slug": "40", "name": "3", "size": "1.5rem" },
				{ "slug": "50", "name": "4", "size": "2.5rem" },
				{ "slug": "60", "name": "5", "size": "4rem" }
			]
		}
	},
	"styles": {
		"color": { "background": "var(--wp--preset--color--base)", "text": "var(--wp--preset--color--contrast)" },
		"typography": { "fontFamily": "var(--wp--preset--font-family--body)", "fontSize": "var(--wp--preset--font-size--medium)", "lineHeight": "1.6" },
		"elements": {
			"heading": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "600", "lineHeight": "1.15" } },
			"link": { "color": { "text": "var(--wp--preset--color--accent)" } }
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
